root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
# Markdown commonly wraps numbered list items with a 3-space continuation
# indent. The CommonMark convention takes precedence over a fixed indent_size.
indent_size = unset

[*.{yml,yaml,json,toml}]
indent_size = 2

# Shell indentation is enforced by shfmt (-i 2). editorconfig-checker has no
# heredoc awareness and over-flags column-aligned usage-text continuations
# inside `cat <<EOF` usage blocks, so indent_size is deferred to shfmt here.
[*.sh]
indent_size = unset

[Makefile]
indent_style = tab
